{% if app.request.hasPreviousSession %}
    <div class="row">
        {% for label, messages in app.flashes %}
            <div class="col-12">
                {% for message in messages %}
                    <div class="alert alert-{{ label }}">
                        {{ message|raw }}
                    </div>
                {% endfor %}
            </div>
        {% endfor %}
    </div>
{%  endif %}
